// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // prod: "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ПОЛЬЗОВАТЕЛИ
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  login     String   @unique
  email     String   @unique
  password  String // bcrypt hash
  role      Role     @default(USER)
  isActive   Boolean   @default(true)
  lastSeenAt DateTime?
  createdAt DateTime @default(now())

  // Telegram
  telegramChatId  String?  @unique
  tgNotifyAssign  Boolean  @default(true)
  tgNotifyComment Boolean  @default(true)
  tgNotifyMove    Boolean  @default(true)
  tgNotifyProject Boolean  @default(true) // kept for compat with existing records

  // Relations
  ownedWorkspaces    Workspace[]         @relation("WorkspaceOwner")
  memberships        WorkspaceMember[]
  taskAssignments    TaskAssignee[]      @relation("TaskAssignee")
  comments           Comment[]
  attachments        Attachment[]
  notifications      Notification[]      @relation("NotificationRecipient")
  actedNotifications Notification[]      @relation("NotificationActor")
  movedTasks         ColumnMoveLog[]
  telegramTokens     TelegramLinkToken[]
  activityLogs       ActivityLog[]       @relation("ActivityActor")
  kbArticlesAuthored KbArticle[]         @relation("KbArticleAuthor")
  kbArticlesEdited   KbArticle[]         @relation("KbArticleEditor")
  kbArticleVersions  KbArticleVersion[]
  kbFilesUploaded    KbFile[]            @relation("KbFileUploader")
  kbCrawlsInitiated  KbCrawl[]           @relation("KbCrawlInitiator")

  // Critical event Telegram notifications (default false)
  tgNotifyTaskDeleted      Boolean @default(false)
  tgNotifyMemberRemoved    Boolean @default(false)
  tgNotifyWorkspaceDeleted Boolean @default(false)
  tgNotifyRoleChanged      Boolean @default(false)

  @@index([email])
  @@index([login])
}

enum Role {
  ADMIN
  USER
}

// ─────────────────────────────────────────
// WORKSPACE (бывший Project)
// ─────────────────────────────────────────

model Workspace {
  id          String  @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  members       WorkspaceMember[]
  modules       WorkspaceModule[]
  columns       Column[]
  tasks         Task[]
  labels        Label[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  kbCategories  KbCategory[]
  kbTags        KbTag[]
  kbArticles    KbArticle[]
  kbFiles       KbFile[]
  kbCrawls      KbCrawl[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

enum MemberRole {
  OWNER
  MEMBER
}

// ─────────────────────────────────────────
// МОДУЛИ WORKSPACE
// ─────────────────────────────────────────

model WorkspaceModule {
  id          String   @id @default(cuid())
  workspaceId String
  moduleKey   String   // "crm" | "knowledge" | "tickets" | "logs" | "chat" | "marketing" | "analytics" | "users"
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, moduleKey])
  @@index([workspaceId])
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─────────────────────────────────────────
// КОЛОНКИ
// ─────────────────────────────────────────

model Column {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  position    Int // порядок на доске
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([workspaceId, position])
  @@index([workspaceId])
}

// ─────────────────────────────────────────
// ЗАДАЧИ
// ─────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  workspaceId String
  columnId    String
  title       String
  description String?
  priority    TaskPriority @default(NONE)
  position    Int // порядок внутри колонки
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column    Column    @relation(fields: [columnId], references: [id], onDelete: Restrict)

  assignees      TaskAssignee[]
  labels         TaskLabel[]
  checklistItems ChecklistItem[]
  timeIntervals  TimeInterval[]
  moveLogs       ColumnMoveLog[]
  comments       Comment[]
  attachments    Attachment[]
  notifications  Notification[]

  @@index([workspaceId])
  @@index([columnId])
}

model TaskAssignee {
  id     String @id @default(cuid())
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

// ─────────────────────────────────────────
// МЕТКИ
// ─────────────────────────────────────────

model Label {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String // hex color, e.g. "#ef4444"

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model TaskLabel {
  id      String @id @default(cuid())
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@index([taskId])
  @@index([labelId])
}

// ─────────────────────────────────────────
// ЧЕК-ЛИСТ
// ─────────────────────────────────────────

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  text      String
  checked   Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, position])
}

// ─────────────────────────────────────────
// УЧЁТ ВРЕМЕНИ
// ─────────────────────────────────────────

model TimeInterval {
  id        String    @id @default(cuid())
  taskId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime? // null = интервал открыт (задача в работе)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, endedAt])
}

// ─────────────────────────────────────────
// ИСТОРИЯ ПЕРЕМЕЩЕНИЙ
// ─────────────────────────────────────────

model ColumnMoveLog {
  id             String   @id @default(cuid())
  taskId         String
  movedByUserId  String
  movedAt        DateTime @default(now())
  fromColumnName String
  toColumnName   String

  task    Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  movedBy User @relation(fields: [movedByUserId], references: [id], onDelete: Restrict)

  @@index([taskId])
}

// ─────────────────────────────────────────
// КОММЕНТАРИИ
// ─────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([taskId])
}

// ─────────────────────────────────────────
// ВЛОЖЕНИЯ
// ─────────────────────────────────────────

model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  uploadedById String
  originalName String
  size         Int // bytes
  mimeType     String
  storagePath  String // uploads/{workspaceId}/{taskId}/{uuid}-{originalName}
  uploadedAt   DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([taskId])
}

// ─────────────────────────────────────────
// УВЕДОМЛЕНИЯ
// ─────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType
  taskId      String?
  workspaceId String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User      @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User?     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  task      Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead])
}

enum NotificationType {
  ASSIGNED
  COMMENTED
  MOVED
  PROJECT_ADDED
}

// ─────────────────────────────────────────
// TELEGRAM: одноразовые коды привязки
// ─────────────────────────────────────────

model TelegramLinkToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime // now + 10 min

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ─────────────────────────────────────────
// ЛОГИ АКТИВНОСТИ
// ─────────────────────────────────────────

enum ActivityAction {
  // Task actions
  TASK_CREATED
  TASK_DELETED
  TASK_MOVED
  TASK_UPDATED
  TASK_ASSIGNEE_ADDED
  TASK_ASSIGNEE_REMOVED
  TASK_LABEL_ADDED
  TASK_LABEL_REMOVED
  TASK_PRIORITY_CHANGED
  TASK_DATE_CHANGED
  TASK_CHECKLIST_ITEM_ADDED
  TASK_CHECKLIST_ITEM_TOGGLED
  TASK_CHECKLIST_ITEM_REMOVED

  // Comment & Attachment
  COMMENT_CREATED
  COMMENT_UPDATED
  COMMENT_DELETED
  ATTACHMENT_UPLOADED
  ATTACHMENT_DELETED

  // Column
  COLUMN_CREATED
  COLUMN_RENAMED
  COLUMN_DELETED
  COLUMN_REORDERED

  // Workspace
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  MEMBER_ADDED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED
  MODULE_ENABLED
  MODULE_DISABLED

  // Knowledge Base
  KB_ARTICLE_CREATED
  KB_ARTICLE_UPDATED
  KB_ARTICLE_DELETED
  KB_ARTICLE_VERSION_RESTORED
  KB_CATEGORY_CREATED
  KB_CATEGORY_UPDATED
  KB_CATEGORY_DELETED
  KB_TAG_CREATED
  KB_TAG_DELETED
  KB_ARTICLE_IMPORTED_FROM_FILE
  KB_ARTICLE_IMPORTED_FROM_URL
  KB_FILE_UPLOADED
  KB_FILE_DELETED
  KB_ARTICLE_REFRESHED_FROM_URL
  KB_CRAWL_STARTED
  KB_CRAWL_COMPLETED
  KB_CRAWL_FAILED
  KB_CRAWL_CANCELLED

  // System
  USER_LOGIN
  USER_LOGOUT
  USER_CREATED_BY_ADMIN
  USER_DEACTIVATED
  USER_ACTIVATED
  USER_PASSWORD_RESET
  USER_ROLE_CHANGED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model ActivityLog {
  id          String         @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      ActivityAction
  entityType  String?
  entityId    String?
  summary     String
  metadata    String // JSON.stringify (SQLite doesn't support Json)

  // Denormalized for fast filtering
  taskId   String?
  columnId String?

  createdAt DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?      @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorId])
  @@index([action])
  @@index([taskId])
  @@index([columnId])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// БАЗА ЗНАНИЙ
// ─────────────────────────────────────────

enum KbSourceType {
  MANUAL
  FILE
  URL
}

model KbCategory {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  color       String
  icon        String?
  position    Int

  createdAt DateTime @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  articles  KbArticle[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, position])
}

model KbTag {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  articles  KbArticleTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model KbArticle {
  id          String       @id @default(cuid())
  workspaceId String
  title       String
  slug        String
  content     String

  categoryId String?

  sourceType      KbSourceType @default(MANUAL)
  sourceUrl       String?
  sourceFileId    String?
  sourceFile      KbFile?      @relation("ArticleSourceFile", fields: [sourceFileId], references: [id], onDelete: SetNull)
  lastSyncedAt    DateTime?

  authorId       String?
  lastEditedById String?
  isPublished    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category     KbCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author       User?              @relation("KbArticleAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  lastEditedBy User?              @relation("KbArticleEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  tags         KbArticleTag[]
  versions     KbArticleVersion[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isPublished, updatedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([sourceFileId])
}

model KbArticleTag {
  articleId String
  tagId     String

  article KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     KbTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

model KbArticleVersion {
  id        String @id @default(cuid())
  articleId String

  title   String
  content String

  editedById String?
  editedAt   DateTime @default(now())
  reason     String?

  article  KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editedBy User?     @relation(fields: [editedById], references: [id], onDelete: SetNull)

  @@index([articleId, editedAt])
}

model KbFile {
  id           String   @id @default(cuid())
  workspaceId  String
  uploadedById String?
  originalName String
  size         Int // bytes
  mimeType     String
  storagePath  String

  uploadedAt DateTime @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy User?       @relation("KbFileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  articles   KbArticle[] @relation("ArticleSourceFile")

  @@index([workspaceId, uploadedAt])
  @@index([uploadedById])
}

// ─────────────────────────────────────────
// KB CRAWL
// ─────────────────────────────────────────

enum KbCrawlStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model KbCrawl {
  id          String        @id @default(cuid())
  workspaceId String
  startUrl    String

  maxPages  Int @default(500)
  maxDepth  Int @default(5)
  timeoutMs Int @default(900000)

  status      KbCrawlStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?

  pagesFound     Int @default(0)
  pagesCompleted Int @default(0)
  pagesFailed    Int @default(0)
  currentDepth   Int @default(0)

  articlesCreated Int @default(0)
  articlesUpdated Int @default(0)

  error         String?
  initiatedById String?
  createdAt     DateTime @default(now())

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  initiatedBy User?         @relation("KbCrawlInitiator", fields: [initiatedById], references: [id], onDelete: SetNull)
  pages       KbCrawlPage[]

  @@index([workspaceId, status])
  @@index([initiatedById])
}

model KbCrawlPage {
  id        String    @id @default(cuid())
  crawlId   String
  url       String
  depth     Int
  status    String // "pending" | "completed" | "failed" | "skipped"
  fetchedAt DateTime?
  error     String?
  articleId String?

  crawl KbCrawl @relation(fields: [crawlId], references: [id], onDelete: Cascade)

  @@unique([crawlId, url])
  @@index([crawlId, status])
}

model SystemLog {
  id         String   @id @default(cuid())
  level      LogLevel @default(INFO)
  source     String
  method     String?
  path       String?
  statusCode Int?
  durationMs Int?
  message    String
  errorStack String?
  metadata   String?

  workspaceId String?
  userId      String?

  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@index([source])
  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
}
