// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// Отдельный клиент для yt-parser (единая схема и БД, см. ТЗ unification Шаг 3)
generator ytparser {
  provider = "prisma-client-js"
  output   = "../tools/yt-parser/db/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ПОЛЬЗОВАТЕЛИ
// ─────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  login             String    @unique
  email             String    @unique
  password          String // bcrypt hash
  role              Role      @default(USER)
  isActive          Boolean   @default(true)
  avatarPath        String?
  lastSeenAt        DateTime?
  createdAt         DateTime  @default(now())
  // Bumped on password change → JWTs issued before this are invalidated
  // (other sessions logged out; the changing session is re-issued in place).
  passwordChangedAt DateTime?

  // Telegram
  telegramChatId  String? @unique
  tgNotifyAssign  Boolean @default(true)
  tgNotifyComment Boolean @default(true)
  tgNotifyMove    Boolean @default(true)
  tgNotifyProject Boolean @default(true) // kept for compat with existing records
  tgNotifyContent Boolean @default(true) // контент-план: вычитка / правки / одобрено

  // Relations
  ownedWorkspaces    Workspace[]         @relation("WorkspaceOwner")
  memberships        WorkspaceMember[]
  taskAssignments    TaskAssignee[]      @relation("TaskAssignee")
  createdTasks       Task[]              @relation("TaskCreator")
  comments           Comment[]
  attachments        Attachment[]
  notifications      Notification[]      @relation("NotificationRecipient")
  actedNotifications Notification[]      @relation("NotificationActor")
  movedTasks         ColumnMoveLog[]
  telegramTokens     TelegramLinkToken[]
  activityLogs       ActivityLog[]       @relation("ActivityActor")
  kbArticlesAuthored KbArticle[]         @relation("KbArticleAuthor")
  kbArticlesEdited   KbArticle[]         @relation("KbArticleEditor")
  kbArticleVersions  KbArticleVersion[]
  kbFilesUploaded    KbFile[]            @relation("KbFileUploader")
  kbCrawlsInitiated  KbCrawl[]           @relation("KbCrawlInitiator")

  // Tickets
  ticketsAsInternalCreator  Ticket[]             @relation("TicketInternalCreator")
  ticketsAsAssignee         Ticket[]             @relation("TicketAssignee")
  ticketsAsResolver         Ticket[]             @relation("TicketResolver")
  ticketMessagesAsManager   TicketMessage[]      @relation("TicketMessageManagerAuthor")
  ticketAttachmentsUploaded TicketAttachment[]   @relation("TicketAttachmentUploader")
  ticketCollaborations      TicketCollaborator[] @relation("TicketCollaborator")

  // Critical event Telegram notifications (default false)
  tgNotifyTaskDeleted      Boolean @default(false)
  tgNotifyMemberRemoved    Boolean @default(false)
  tgNotifyWorkspaceDeleted Boolean @default(false)
  tgNotifyRoleChanged      Boolean @default(false)

  // Ticket Telegram notifications
  tgNotifyTicketAssigned    Boolean @default(true)
  tgNotifyTicketMessage     Boolean @default(true)
  tgNotifyTicketSlaBreached Boolean @default(true)

  // Deploy notifications (admin only)
  tgNotifyDeploy Boolean @default(true)

  // Chat
  tgNotifyChat           Boolean             @default(true)
  chatSoundEnabled       Boolean             @default(true)
  chatDesktopNotify      Boolean             @default(true)
  chatChannelMemberships ChatChannelMember[]
  chatMessages           ChatMsg[]           @relation("ChatMsgAuthor")
  chatReactions          ChatMsgReaction[]
  globalChatMessages     GlobalChatMsg[]     @relation("GlobalChatAuthor")
  chatBookmarks          ChatMsgBookmark[]

  // Voice
  voiceParticipations VoiceParticipant[]
  voiceMessages       VoiceMessage[]

  // Member activity tracking
  memberActivities MemberActivity[]

  // Content plan
  contentCardsAuthored ContentCard[]        @relation("ContentCardAuthor")
  contentCardsAssigned ContentCard[]        @relation("ContentCardAssignee")
  contentCardHistory   ContentCardHistory[]

  @@index([lastSeenAt])
}

enum Role {
  ADMIN
  USER
}

// ─────────────────────────────────────────
// WORKSPACE (бывший Project)
// ─────────────────────────────────────────

enum CustomerIdentityMethod {
  EMAIL_WITH_NAME
  EMAIL_ONLY
  ANONYMOUS
  TELEGRAM_LOGIN
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoPath    String?
  createdAt   DateTime @default(now())

  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  // Chat settings
  chatTitle               String?
  chatSubtitle            String?
  chatAccentColor         String?
  chatLogoUrl             String?
  chatIdentityMethod      CustomerIdentityMethod @default(EMAIL_WITH_NAME)
  chatPersonaRotation     Boolean                @default(true)
  chatAllowedEmbedOrigins String?
  chatTimezone            String                 @default("Europe/Moscow")

  // External integrations
  externalAnalyticsUrl String?

  members             WorkspaceMember[]
  modules             WorkspaceModule[]
  columns             Column[]
  tasks               Task[]
  labels              Label[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  kbCategories        KbCategory[]
  kbTags              KbTag[]
  kbArticles          KbArticle[]
  kbFiles             KbFile[]
  kbCrawls            KbCrawl[]
  customers           Customer[]
  tickets             Ticket[]
  chatPersonas        ChatPersona[]
  cannedResponses     CannedResponse[]
  emailConfig         WorkspaceEmailConfig?
  agentConfig         AgentConfig?
  chatChannels        ChatChannel[]
  voiceRooms          VoiceRoom[]
  serviceAccounts     ServiceAccount[]
  externalUsersConfig ExternalUsersConfig?

  // Marketing
  mktConfig        MktConfig?
  mktProjects      MktProject[]
  mktLeads         MktLead[]
  mktSearchTasks   MktSearchTask[]
  mktSegments      MktSegment[]
  mktTemplates     MktTemplate[]
  mktKnowledgeDocs MktKnowledgeDoc[]
  mktDailyCounters MktDailyCounter[]
  mktSettings      MktSetting[]
  mktTags          MktTag[]
  mktTgAccounts    MktTgAccount[]

  // Member activity tracking
  memberActivities MemberActivity[]

  // Content plan
  contentCards ContentCard[]

  @@index([ownerId])
}

// ─────────────────────────────────────────
// SERVICE ACCOUNTS (M2M API доступ)
// ─────────────────────────────────────────

model ServiceAccount {
  id         String    @id @default(cuid())
  name       String
  tokenHash  String    @unique // SHA-256 hash of Bearer token
  scopes     String // JSON array: ["tasks:read","tickets:read",...]
  allowedIPs String? // JSON array: ["187.127.88.96"]. null = any IP
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  @@index([workspaceId])
}

// ─────────────────────────────────────────
// EXTERNAL USERS (подключение сторонних проектов)
// ─────────────────────────────────────────

model ExternalUsersConfig {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  apiEndpoint String
  apiKey      String
  authType    String    @default("bearer") // "bearer" | "x-api-key" | "query"
  isConnected Boolean   @default(false)
  lastSyncAt  DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// VOICE CHANNELS
// ─────────────────────────────────────────

model VoiceRoom {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  isDefault      Boolean  @default(false)
  isPrivate      Boolean  @default(false)
  allowedUserIds String   @default("[]") // JSON array of userIds
  createdAt      DateTime @default(now())

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  participants VoiceParticipant[]
  signals      VoiceSignal[]
  messages     VoiceMessage[]
  sessions     VoiceSession[]

  @@index([workspaceId])
}

model VoiceParticipant {
  id              String   @id @default(cuid())
  roomId          String
  userId          String?
  guestName       String?
  guestToken      String?
  isMuted         Boolean  @default(false)
  isScreenSharing Boolean  @default(false)
  joinedAt        DateTime @default(now())
  lastHeartbeat   DateTime @default(now())

  room VoiceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model VoiceSignal {
  id         String    @id @default(cuid())
  roomId     String
  fromUserId String
  toUserId   String
  type       String // "offer" | "answer" | "ice-candidate"
  payload    String // JSON
  createdAt  DateTime  @default(now())
  consumedAt DateTime?

  room VoiceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, toUserId, consumedAt])
}

model VoiceMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String?
  guestName String?
  content   String
  createdAt DateTime @default(now())

  room VoiceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

model VoiceSession {
  id           String    @id @default(cuid())
  roomId       String
  roomName     String
  workspaceId  String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  duration     Int? // seconds
  participants String // JSON array of {userId, login, guestName}
  summary      String? // AI summary

  room VoiceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startedAt])
}

model WorkspaceMember {
  id             String     @id @default(cuid())
  workspaceId    String
  userId         String
  role           MemberRole @default(MEMBER)
  joinedAt       DateTime   @default(now())
  allowedModules String? // JSON array, e.g. ["marketing","marketing:parsers:youtube"]. null = full access

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

// ─────────────────────────────────────────
// УЧЁТ ВРЕМЕНИ УЧАСТНИКОВ (heartbeat-based)
// ─────────────────────────────────────────

model MemberActivity {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date          String // "2026-05-22" (ISO date string)
  minutesActive Int       @default(0)
  firstSeenAt   DateTime?
  lastSeenAt    DateTime?
  heartbeats    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, workspaceId, date])
  @@index([workspaceId, date])
  @@index([userId, date])
}

enum MemberRole {
  OWNER
  MEMBER
}

// ─────────────────────────────────────────
// МОДУЛИ WORKSPACE
// ─────────────────────────────────────────

model WorkspaceModule {
  id          String   @id @default(cuid())
  workspaceId String
  moduleKey   String // "crm" | "knowledge" | "tickets" | "logs" | "chat" | "marketing" | "analytics" | "users"
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, moduleKey])
  @@index([workspaceId])
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─────────────────────────────────────────
// КОЛОНКИ
// ─────────────────────────────────────────

model Column {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  position    Int // порядок на доске
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([workspaceId, position])
  @@index([workspaceId])
}

// ─────────────────────────────────────────
// ЗАДАЧИ
// ─────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  workspaceId String
  columnId    String
  title       String
  description String?
  priority    TaskPriority @default(NONE)
  position    Int // порядок внутри колонки
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  createdById String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column    Column    @relation(fields: [columnId], references: [id], onDelete: Restrict)
  createdBy User?     @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  assignees      TaskAssignee[]
  labels         TaskLabel[]
  checklistItems ChecklistItem[]
  timeIntervals  TimeInterval[]
  moveLogs       ColumnMoveLog[]
  comments       Comment[]
  attachments    Attachment[]
  notifications  Notification[]

  @@index([workspaceId])
  @@index([columnId])
  @@index([createdById])
}

model TaskAssignee {
  id     String @id @default(cuid())
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

// ─────────────────────────────────────────
// МЕТКИ
// ─────────────────────────────────────────

model Label {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String // hex color, e.g. "#ef4444"

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model TaskLabel {
  id      String @id @default(cuid())
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@index([taskId])
  @@index([labelId])
}

// ─────────────────────────────────────────
// ЧЕК-ЛИСТ
// ─────────────────────────────────────────

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  text      String
  checked   Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, position])
}

// ─────────────────────────────────────────
// УЧЁТ ВРЕМЕНИ
// ─────────────────────────────────────────

model TimeInterval {
  id        String    @id @default(cuid())
  taskId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime? // null = интервал открыт (задача в работе)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, endedAt])
}

// ─────────────────────────────────────────
// ИСТОРИЯ ПЕРЕМЕЩЕНИЙ
// ─────────────────────────────────────────

model ColumnMoveLog {
  id             String   @id @default(cuid())
  taskId         String
  movedByUserId  String
  movedAt        DateTime @default(now())
  fromColumnName String
  toColumnName   String

  task    Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  movedBy User @relation(fields: [movedByUserId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([movedByUserId])
}

// ─────────────────────────────────────────
// КОММЕНТАРИИ
// ─────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([authorId])
}

// ─────────────────────────────────────────
// ВЛОЖЕНИЯ
// ─────────────────────────────────────────

model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  uploadedById String
  originalName String
  size         Int // bytes
  mimeType     String
  storagePath  String // uploads/{workspaceId}/{taskId}/{uuid}-{originalName}
  uploadedAt   DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([uploadedById])
}

// ─────────────────────────────────────────
// УВЕДОМЛЕНИЯ
// ─────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType
  taskId      String?
  cardId      String? // карточка контент-плана
  workspaceId String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User         @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User?        @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  task      Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  card      ContentCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  workspace Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
}

enum NotificationType {
  ASSIGNED
  COMMENTED
  MOVED
  PROJECT_ADDED
  CONTENT_REVIEW // карточка пришла на вычитку (модератору)
  CONTENT_CHANGES // карточку вернули на правки (автору)
  CONTENT_APPROVED // карточку одобрили (автору)
}

// ─────────────────────────────────────────
// TELEGRAM: одноразовые коды привязки
// ─────────────────────────────────────────

model TelegramLinkToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime // now + 10 min

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// ЛОГИ АКТИВНОСТИ
// ─────────────────────────────────────────

enum ActivityAction {
  // Task actions
  TASK_CREATED
  TASK_DELETED
  TASK_MOVED
  TASK_UPDATED
  TASK_ASSIGNEE_ADDED
  TASK_ASSIGNEE_REMOVED
  TASK_LABEL_ADDED
  TASK_LABEL_REMOVED
  TASK_PRIORITY_CHANGED
  TASK_DATE_CHANGED
  TASK_CHECKLIST_ITEM_ADDED
  TASK_CHECKLIST_ITEM_TOGGLED
  TASK_CHECKLIST_ITEM_REMOVED

  // Comment & Attachment
  COMMENT_CREATED
  COMMENT_UPDATED
  COMMENT_DELETED
  ATTACHMENT_UPLOADED
  ATTACHMENT_DELETED

  // Column
  COLUMN_CREATED
  COLUMN_RENAMED
  COLUMN_DELETED
  COLUMN_REORDERED

  // Workspace
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  MEMBER_ADDED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED
  MODULE_ENABLED
  MODULE_DISABLED

  // Knowledge Base
  KB_ARTICLE_CREATED
  KB_ARTICLE_UPDATED
  KB_ARTICLE_DELETED
  KB_ARTICLE_VERSION_RESTORED
  KB_CATEGORY_CREATED
  KB_CATEGORY_UPDATED
  KB_CATEGORY_DELETED
  KB_TAG_CREATED
  KB_TAG_DELETED
  KB_ARTICLE_IMPORTED_FROM_FILE
  KB_ARTICLE_IMPORTED_FROM_URL
  KB_FILE_UPLOADED
  KB_FILE_DELETED
  KB_ARTICLE_REFRESHED_FROM_URL
  KB_CRAWL_STARTED
  KB_CRAWL_COMPLETED
  KB_CRAWL_FAILED
  KB_CRAWL_CANCELLED
  KB_SEARCH_PERFORMED

  // Tickets
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_STATUS_CHANGED
  TICKET_ASSIGNED
  TICKET_MESSAGE_ADDED
  TICKET_SLA_BREACHED
  TICKET_DELETED
  CUSTOMER_CREATED
  CUSTOMER_UPDATED

  // Chat
  CHAT_SETTINGS_UPDATED
  CHAT_PERSONA_CREATED
  CHAT_PERSONA_UPDATED
  CHAT_PERSONA_DELETED

  // Canned Responses & CSAT
  CANNED_RESPONSE_CREATED
  CANNED_RESPONSE_UPDATED
  CANNED_RESPONSE_DELETED
  TICKET_RATED
  EMAIL_CONFIG_UPDATED
  AGENT_CONFIG_UPDATED
  AGENT_SCENARIO_CREATED
  AGENT_SCENARIO_UPDATED
  AGENT_SCENARIO_DELETED
  AGENT_RESPONSE_GENERATED

  // Chat
  CHAT_CHANNEL_CREATED
  CHAT_MESSAGE_SENT

  // Marketing
  MKT_LEAD_CREATED
  MKT_LEAD_UPDATED
  MKT_LEAD_DELETED
  MKT_LEAD_ENRICHED
  MKT_LEAD_SCORED
  MKT_PROJECT_CREATED
  MKT_PROJECT_UPDATED
  MKT_PROJECT_DELETED
  MKT_CAMPAIGN_STARTED
  MKT_CAMPAIGN_PAUSED
  MKT_PARSER_STARTED
  MKT_PARSER_COMPLETED
  MKT_PARSER_FAILED
  MKT_OUTREACH_SENT
  MKT_OUTREACH_REPLIED
  MKT_DEAL_CREATED
  MKT_DEAL_APPROVED
  MKT_DEAL_REJECTED

  // System
  USER_LOGIN
  USER_LOGOUT
  USER_CREATED_BY_ADMIN
  USER_DEACTIVATED
  USER_ACTIVATED
  USER_PASSWORD_RESET
  USER_ROLE_CHANGED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model ActivityLog {
  id          String         @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      ActivityAction
  entityType  String?
  entityId    String?
  summary     String
  metadata    String // JSON.stringify (SQLite doesn't support Json)

  // Denormalized for fast filtering
  taskId   String?
  columnId String?

  createdAt DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?      @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorId])
  @@index([action])
  @@index([taskId])
  @@index([columnId])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// DEPLOY TRACKING
// ─────────────────────────────────────────

model DeployMessage {
  id        String   @id @default(cuid())
  commitSha String
  chatId    String
  messageId Int // Telegram message_id for editing
  status    String   @default("building") // building | done | failed
  createdAt DateTime @default(now())

  @@index([status])
}

// ─────────────────────────────────────────
// БАЗА ЗНАНИЙ
// ─────────────────────────────────────────

enum KbSourceType {
  MANUAL
  FILE
  URL
}

model KbCategory {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  color       String
  icon        String?
  position    Int

  createdAt DateTime @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  articles  KbArticle[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, position])
}

model KbTag {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  articles  KbArticleTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model KbArticle {
  id          String @id @default(cuid())
  workspaceId String
  title       String
  slug        String
  content     String

  categoryId String?

  sourceType   KbSourceType @default(MANUAL)
  sourceUrl    String?
  sourceFileId String?
  sourceFile   KbFile?      @relation("ArticleSourceFile", fields: [sourceFileId], references: [id], onDelete: SetNull)
  lastSyncedAt DateTime?

  // Search (KB-1c)
  searchText          String?
  searchTextUpdatedAt DateTime?

  // Embeddings — reserved for KB-2 (Voyage AI)
  embedding          String? // JSON.stringify(number[])
  embeddingModel     String? // e.g. "voyage-3-large"
  embeddingUpdatedAt DateTime?

  authorId       String?
  lastEditedById String?
  isPublished    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category     KbCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author       User?              @relation("KbArticleAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  lastEditedBy User?              @relation("KbArticleEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  tags         KbArticleTag[]
  versions     KbArticleVersion[]
  chunks       KbChunk[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isPublished, updatedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([sourceFileId])
}

model KbArticleTag {
  articleId String
  tagId     String

  article KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     KbTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

model KbArticleVersion {
  id        String @id @default(cuid())
  articleId String

  title   String
  content String

  editedById String?
  editedAt   DateTime @default(now())
  reason     String?

  article  KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editedBy User?     @relation(fields: [editedById], references: [id], onDelete: SetNull)

  @@index([articleId, editedAt])
}

model KbFile {
  id           String  @id @default(cuid())
  workspaceId  String
  uploadedById String?
  originalName String
  size         Int // bytes
  mimeType     String
  storagePath  String

  // Auto-extracted document content
  extractedText   String?
  extractedAt     DateTime?
  extractionError String?

  uploadedAt DateTime @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy User?       @relation("KbFileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  articles   KbArticle[] @relation("ArticleSourceFile")
  chunks     KbChunk[]

  @@index([workspaceId, uploadedAt])
  @@index([uploadedById])
}

// KB vector chunks (KB-vector step 1). Chunk-level embeddings (Xenova e5-small,
// 384-dim, stored as JSON float[] in `embedding`). Additive — NOT wired into
// ingest/search/agent yet (steps 2-4).
model KbChunk {
  id             String   @id @default(cuid())
  workspaceId    String
  articleId      String?
  fileId         String?
  sourceKind     String // "article" | "file"
  position       Int
  chunkText      String
  embedding      String? // JSON.stringify(number[])
  embeddingModel String?
  tokenCount     Int?
  createdAt      DateTime @default(now())

  article KbArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  file    KbFile?    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([articleId])
  @@index([fileId])
}

// ─────────────────────────────────────────
// KB CRAWL
// ─────────────────────────────────────────

enum KbCrawlStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model KbCrawl {
  id          String @id @default(cuid())
  workspaceId String
  startUrl    String

  maxPages  Int @default(500)
  maxDepth  Int @default(5)
  timeoutMs Int @default(900000)

  status      KbCrawlStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?

  pagesFound     Int @default(0)
  pagesCompleted Int @default(0)
  pagesFailed    Int @default(0)
  currentDepth   Int @default(0)

  articlesCreated Int @default(0)
  articlesUpdated Int @default(0)

  error         String?
  initiatedById String?
  createdAt     DateTime @default(now())

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  initiatedBy User?         @relation("KbCrawlInitiator", fields: [initiatedById], references: [id], onDelete: SetNull)
  pages       KbCrawlPage[]

  @@index([workspaceId, status])
  @@index([initiatedById])
}

model KbCrawlPage {
  id        String    @id @default(cuid())
  crawlId   String
  url       String
  depth     Int
  status    String // "pending" | "completed" | "failed" | "skipped"
  fetchedAt DateTime?
  error     String?
  articleId String?

  crawl KbCrawl @relation(fields: [crawlId], references: [id], onDelete: Cascade)

  @@unique([crawlId, url])
  @@index([crawlId, status])
}

model KbSearchHistory {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  query       String
  resultCount Int
  searchedAt  DateTime @default(now())

  @@index([userId, searchedAt])
  @@index([workspaceId, searchedAt])
}

// ─────────────────────────────────────────
// ТИКЕТЫ
// ─────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  FINANCIAL
  TECHNICAL
  GENERAL
  BUG
  FEATURE_REQUEST
}

enum TicketSource {
  INTERNAL
  EXTERNAL
  EMAIL
}

enum TicketMessageAuthorType {
  MANAGER
  CUSTOMER
  SYSTEM
  AGENT
}

model Customer {
  id          String  @id @default(cuid())
  workspaceId String
  email       String
  name        String?
  externalId  String?
  metadata    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tickets     Ticket[]
  messages    TicketMessage[]
  attachments TicketAttachment[]
  ratings     TicketRating[]

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([externalId])
}

model Ticket {
  id          String @id @default(cuid())
  workspaceId String
  number      Int

  title       String
  description String

  source   TicketSource
  category TicketCategory @default(GENERAL)
  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  slaDeadline DateTime?
  slaBreached Boolean   @default(false)

  internalCreatorId String?
  customerId        String?

  assigneeId String?
  assignedAt DateTime?

  needsHumanHelp  Boolean   @default(false)
  helpRequestedAt DateTime?
  agentConfidence Float?

  resolvedAt   DateTime?
  resolvedById String?
  closedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  internalCreator User?     @relation("TicketInternalCreator", fields: [internalCreatorId], references: [id], onDelete: SetNull)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignee        User?     @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  resolvedBy      User?     @relation("TicketResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  messages      TicketMessage[]
  attachments   TicketAttachment[]
  rating        TicketRating?
  collaborators TicketCollaborator[]

  @@unique([workspaceId, number])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, assigneeId])
  @@index([workspaceId, slaDeadline])
  @@index([customerId])
}

model TicketCollaborator {
  id       String   @id @default(cuid())
  ticketId String
  userId   String
  role     String   @default("collaborator") // "collaborator" | "reviewer" | "observer"
  addedAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation("TicketCollaborator", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@index([ticketId])
  @@index([userId])
}

model TicketMessage {
  id       String @id @default(cuid())
  ticketId String

  authorType TicketMessageAuthorType

  managerAuthorId  String?
  customerAuthorId String?

  content      String
  systemAction String?
  metadata     String?

  createdAt DateTime @default(now())

  ticket         Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  managerAuthor  User?     @relation("TicketMessageManagerAuthor", fields: [managerAuthorId], references: [id], onDelete: SetNull)
  customerAuthor Customer? @relation(fields: [customerAuthorId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
}

model TicketAttachment {
  id        String  @id @default(cuid())
  ticketId  String
  messageId String?

  originalName String
  size         Int
  mimeType     String
  storagePath  String

  uploadedById         String?
  uploadedByCustomerId String?

  uploadedAt DateTime @default(now())

  ticket             Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy         User?     @relation("TicketAttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedByCustomer Customer? @relation(fields: [uploadedByCustomerId], references: [id], onDelete: SetNull)

  @@index([ticketId])
}

// ─────────────────────────────────────────
// ЧАТ (внутренний мессенджер)
// ─────────────────────────────────────────

enum ChatChannelType {
  GENERAL // авто-создаётся, все участники, нельзя удалить
  PUBLIC // виден всем, можно присоединиться
  PRIVATE // только по приглашению
  DM // личные сообщения (2 участника)
}

model ChatChannel {
  id          String          @id @default(cuid())
  workspaceId String
  type        ChatChannelType @default(PUBLIC)
  name        String? // null для DM
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   ChatChannelMember[]
  messages  ChatMsg[]

  @@index([workspaceId, type])
}

model ChatChannelMember {
  id         String    @id @default(cuid())
  channelId  String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime  @default(now())
  muted      Boolean   @default(false)
  typingAt   DateTime? // null = not typing

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
}

model ChatMsg {
  id        String    @id @default(cuid())
  channelId String
  authorId  String
  content   String
  parentId  String? // thread reply
  editedAt  DateTime?
  deletedAt DateTime? // soft delete

  // Links
  linkedTicketId String?
  linkedTaskId   String?

  // Forward
  forwardedFromId String? // original message id

  // Pin
  pinnedAt   DateTime?
  pinnedById String?

  createdAt DateTime @default(now())

  channel       ChatChannel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author        User                @relation("ChatMsgAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent        ChatMsg?            @relation("ChatMsgThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies       ChatMsg[]           @relation("ChatMsgThread")
  forwardedFrom ChatMsg?            @relation("ChatMsgForward", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards      ChatMsg[]           @relation("ChatMsgForward")
  reactions     ChatMsgReaction[]
  bookmarks     ChatMsgBookmark[]
  attachments   ChatMsgAttachment[]

  @@index([channelId, deletedAt, createdAt])
  @@index([channelId, createdAt])
  @@index([parentId])
  @@index([forwardedFromId])
}

model ChatMsgReaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String // "👍", "🚀", etc

  message ChatMsg @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChatMsgAttachment {
  id           String   @id @default(cuid())
  messageId    String
  originalName String
  size         Int
  mimeType     String
  storagePath  String
  createdAt    DateTime @default(now())

  message ChatMsg @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ChatMsgBookmark {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message ChatMsg @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

// ─── Global Chat (lobby for all users) ──────────────────────────────────────

model GlobalChatMsg {
  id        String    @id @default(cuid())
  authorId  String
  content   String
  parentId  String?
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  author      User                   @relation("GlobalChatAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent      GlobalChatMsg?         @relation("GlobalReply", fields: [parentId], references: [id], onDelete: SetNull)
  replies     GlobalChatMsg[]        @relation("GlobalReply")
  reactions   GlobalChatReaction[]
  attachments GlobalChatAttachment[]

  @@index([createdAt])
  @@index([parentId])
}

model GlobalChatAttachment {
  id           String   @id @default(cuid())
  messageId    String
  originalName String
  size         Int
  mimeType     String
  storagePath  String
  createdAt    DateTime @default(now())

  message GlobalChatMsg @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model GlobalChatReaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String

  message GlobalChatMsg @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model AgentConfig {
  id          String  @id @default(cuid())
  workspaceId String  @unique
  enabled     Boolean @default(false)

  mode        String @default("copilot") // "copilot" | "autopilot"
  model       String @default("claude-sonnet-4-20250514")
  temperature Float  @default(0.3)

  systemPrompt     String?
  greeting         String?
  guardrails       String? // JSON array of forbidden topics
  handoffThreshold Float   @default(0.7) // confidence below this → human

  autoResolve      Boolean @default(false)
  autoFaq          Boolean @default(false)
  autoContactNotes Boolean @default(false)
  useKnowledgeBase Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scenarios AgentScenario[]
}

model AgentScenario {
  id          String   @id @default(cuid())
  agentId     String
  title       String
  description String
  instruction String
  enabled     Boolean  @default(true)
  position    Int
  createdAt   DateTime @default(now())

  agent AgentConfig @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, position])
}

model WorkspaceEmailConfig {
  id          String  @id @default(cuid())
  workspaceId String  @unique
  enabled     Boolean @default(false)

  // SMTP (outbound)
  smtpHost   String?
  smtpPort   Int?
  smtpUser   String?
  smtpPass   String?
  smtpSecure Boolean @default(true)
  fromEmail  String?
  fromName   String?

  // Inbound webhook secret
  inboundSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CannedResponse {
  id          String   @id @default(cuid())
  workspaceId String
  shortCode   String
  title       String
  content     String
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, shortCode])
  @@index([workspaceId])
}

model TicketRating {
  id         String   @id @default(cuid())
  ticketId   String   @unique
  customerId String
  score      Int
  comment    String?
  createdAt  DateTime @default(now())

  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model ChatPersona {
  id           String   @id @default(cuid())
  workspaceId  String
  displayName  String
  role         String
  bio          String?
  avatarUrl    String?
  position     Int
  scheduleDays String? // JSON array: [1,2] = Mon,Tue. null = every day
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, position])
}

// ─────────────────────────────────────────
// КЛИК-ЛОГИ УЧАСТНИКОВ (action tracking)
// ─────────────────────────────────────────

model MemberClickLog {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  action      String // "page_view", "button_click", "module_open", etc.
  target      String // "marketing:leads", "crm:task:create"
  details     String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  @@index([userId, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([workspaceId, userId, occurredAt])
}

model SystemLog {
  id         String   @id @default(cuid())
  level      LogLevel @default(INFO)
  source     String
  method     String?
  path       String?
  statusCode Int?
  durationMs Int?
  message    String
  errorStack String?
  metadata   String?

  workspaceId String?
  userId      String?

  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@index([source])
  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// МАРКЕТИНГ
// ─────────────────────────────────────────

// ─── Config ─────────────────────────────

model MktConfig {
  id          String @id @default(cuid())
  workspaceId String @unique

  // API keys (encrypted at app level)
  youtubeApiKey     String?
  anthropicApiKey   String?
  apifyToken        String?
  resendApiKey      String?
  resendSenderEmail String?
  resendSenderName  String?
  imapHost          String?
  imapPort          Int?
  imapUser          String?
  imapPass          String?
  tgApiId           String?
  tgApiHash         String?
  tgPhone           String?
  tgSession         String? // serialized gramjs session
  adminBotToken     String?
  adminTgChatId     String?

  // AI models
  claudeModel        String @default("claude-sonnet-4-20250514")
  claudeModelSummary String @default("claude-haiku-4-5-20251001")
  claudeModelComplex String @default("claude-opus-4-20250115")

  // Outreach limits
  dailyCapEmail     Int @default(200)
  dailyCapTg        Int @default(50)
  maxRepliesPerTick Int @default(3)
  loopMessageLimit  Int @default(20)

  // Budget limits
  dailyBudgetApify    Float @default(5)
  monthlyBudgetApify  Float @default(50)
  dailyBudgetClaude   Float @default(3)
  monthlyBudgetClaude Float @default(50)
  budgetAlertPercent  Int   @default(80)

  // Scoring
  scoreModelId         String  @default("claude-haiku-4-5-20251001")
  scoreThresholdHigh   Float   @default(0.75)
  scoreThresholdMedium Float   @default(0.40)
  scoreMinSubscribers  Int     @default(5000)
  scorePrompt          String?

  // Dedup rules
  dedupByEmail    Boolean @default(true)
  dedupByUsername Boolean @default(true)
  dedupByNameGeo  Boolean @default(false)

  // Worker
  reviewMode          Boolean @default(false)
  dryRun              Boolean @default(false)
  followupEnabled     Boolean @default(true)
  followupDelayDays   Int     @default(3)
  followupMaxAttempts Int     @default(2)

  // Warm-up (graduated daily sending limits for new domains)
  warmupEnabled   Boolean   @default(false)
  warmupStartDate DateTime?
  warmupSchedule  String? // JSON array of daily limits, e.g. [5,10,20,30,50,75,100,125,150,175,200]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Projects (campaigns) ───────────────

model MktProject {
  id                  String  @id @default(cuid())
  workspaceId         String
  name                String
  description         String
  uniqueSellingPoints String?
  targetAudience      String?
  budgetMin           Int?
  budgetMax           Int?
  adFormats           String? // JSON array
  language            String  @default("ru")
  isActive            Boolean @default(false)

  // AI agent persona
  agentPersona        String?
  idealChannelProfile String?
  badFitExamples      String?
  proofPoints         String?
  valueProp           String?
  signature           String?
  ctaText             String?
  ctaLink             String?
  creatorEconomics    String?
  toneOfVoice         String?
  stopWords           String? // JSON array

  // Agent settings (yt-parser unification)
  systemPrompt     String?
  adminDirective   String?
  pitchTemperature Float?
  replyDelayMin    Int?
  replyDelayMax    Int?
  subjectPool      String? // JSON
  samplePitches    String? // JSON
  contentRedFlags  String? // JSON
  valuePropShort   String?

  // A/B testing
  abTestEnabled Boolean @default(false)
  abVariants    String? // JSON: [{id:"A", name:"Formal", instructions:"..."}, {id:"B", name:"Casual", instructions:"..."}]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads     MktLead[]
  deals     MktDeal[]

  @@index([workspaceId, isActive])
}

// ─── Leads ──────────────────────────────

enum MktLeadStatus {
  PENDING
  READY
  IN_WORK
  DONE
  REJECTED
}

enum MktDialogueStage {
  NOT_CONTACTED
  QUEUED
  AWAITING_REVIEW
  CONTACTED
  AWAITING_REPLY
  FOLLOWUP_1
  FOLLOWUP_2
  REPLIED
  NEGOTIATING
  DEAL_PENDING
  WON
  LOST
  MOVED_TO_TG
}

enum MktLeadSource {
  YOUTUBE
  TELEGRAM
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  MANUAL
}

model MktLead {
  id          String @id @default(cuid())
  workspaceId String

  // Identity
  channelId   String // unique external id (yt channel id, tg username, etc)
  channelName String?
  channelUrl  String?
  thumbnail   String?
  source      MktLeadSource @default(YOUTUBE)

  // Metrics
  country        String?
  subscribers    Int?
  avgViews       Int?
  engagementRate Float?
  erNormalized   Float?
  erFlags        String? // JSON

  // Contacts
  email       String?
  telegram    String?
  instagram   String?
  twitter     String?
  tiktok      String?
  vk          String?
  discord     String?
  whatsapp    String?
  website     String?
  rawContacts String? // JSON — full contact extraction with sources

  // Status
  leadStatus    MktLeadStatus    @default(PENDING)
  dialogueStage MktDialogueStage @default(NOT_CONTACTED)

  // AI
  leadScore      Float?
  scoreBreakdown String? // JSON
  contentSummary String?
  isDeepSummary  Boolean @default(false)

  // Enrichment
  channelAboutText String?
  channelTags      String? // JSON
  channelLanguage  String?
  mainCategory     String?
  channelAgeDays   Int?
  lastVideoDate    DateTime?
  lastVideosJson   String? // JSON
  topPlaylistsJson String? // JSON
  postingFrequency Float?
  shortsCount      Int?
  shortsRatio      Float?
  shortsAvgViews   Int?
  longAvgViews     Int?

  // Relations
  projectId   String?
  agreedPrice Int?
  notes       String?
  optedOut    Boolean @default(false)

  // yt-parser unification
  keyword   String? // поисковый ключ, по которому найден лид
  tgDraft   String? // черновик телеграм-питча (EN)
  tgDraftRu String? // черновик телеграм-питча (RU)

  // Теги (yt-parser channel_tags: один тег на лида)
  tagId String?
  tag   MktTag? @relation(fields: [tagId], references: [id], onDelete: SetNull)

  // Followup
  lockedUntil      DateTime?
  followupAttempts Int       @default(0)
  lastFollowupAt   DateTime?

  enrichedAt DateTime?
  scoredAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        MktProject?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  dialogues      MktDialogue[]
  deals          MktDeal[]
  consultations  MktConsultation[]
  pendingReplies MktPendingReply[]
  emails         MktLeadEmail[]
  analysis       MktLeadAnalysis?

  @@unique([workspaceId, channelId])
  @@index([workspaceId, leadStatus, dialogueStage])
  @@index([workspaceId, source])
  @@index([workspaceId, leadScore])
  @@index([projectId])
  @@index([email])
}

// Fast email lookup (one lead can have multiple emails)
model MktLeadEmail {
  id     String @id @default(cuid())
  leadId String
  email  String

  lead MktLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, email])
  @@index([email])
}

// TG-аккаунты пула (зеркало tg_account из yt-parser). Чувствительные поля
// (session, twoFa, apiHash, proxyPass) хранятся ШИФРОВАННО (AES-256-GCM, db/crypto.js).
model MktTgAccount {
  id          String @id @default(cuid())
  workspaceId String

  label   String?
  phone   String?
  apiId   Int?
  apiHash String? // ENCRYPTED
  session String? // ENCRYPTED

  proxyType String? @default("socks5")
  proxyHost String?
  proxyPort Int?
  proxyUser String?
  proxyPass String? // ENCRYPTED

  status        String  @default("active")
  firstUsedAt   String?
  sentToday     Int     @default(0)
  sentTodayDate String?
  dailyCap      Int     @default(50)
  floodUntil    BigInt? // ms-таймстамп (как INTEGER в SQLite)
  lastSentAt    String?

  // Импорт Telethon-сессий
  twoFa          String? // ENCRYPTED
  userId         String?
  deviceModel    String?
  systemVersion  String?
  appVersion     String?
  langCode       String?
  systemLangCode String?
  source         String?

  // Профиль (account_profile)
  firstName String?
  lastName  String?
  username  String?
  metadata  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, status])
}

// Теги лидов (yt-parser tags). Имена НЕ unique — в исходной SQLite дубли допускались.
model MktTag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#3b82f6")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads     MktLead[]

  @@index([workspaceId])
}

// Аудит канала на накрутку (yt-parser analysis_*) — 1:1 к лиду
model MktLeadAnalysis {
  id             String    @id @default(cuid())
  leadId         String    @unique
  metrics        String? // analysis_metrics (JSON)
  reasoning      String? // analysis_reasoning
  recommendation String? // analysis_recommendation
  score          Int? // analysis_score
  verdict        String? // analysis_verdict
  analyzedAt     DateTime?
  lead           MktLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// ─── Dialogues & Messages ───────────────

model MktDialogue {
  id               String  @id @default(cuid())
  leadId           String
  channel          String // "email" | "telegram"
  externalThreadId String? // resend email thread / tg chat id
  accountId        String? // исходный tg_account.id из парсера, информационно (tg_account владеет tg-service)

  createdAt DateTime @default(now())

  lead           MktLead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages       MktMessage[]
  pendingReplies MktPendingReply[]

  @@index([leadId])
}

enum MktMsgDirection {
  IN
  OUT
}

enum MktMsgSender {
  AGENT
  ADMIN
  EXTERNAL
}

model MktMessage {
  id         String          @id @default(cuid())
  dialogueId String
  direction  MktMsgDirection
  sender     MktMsgSender
  content    String
  contentRu  String? // RU-версия текста (двуязычный outreach)
  subject    String?
  metadata   String? // JSON (resend_id, headers, etc)
  resendId   String? // for fast email lookup

  // Email open-tracking (yt-parser unification)
  trackingId String?
  openedAt   DateTime?
  openCount  Int       @default(0)

  // A/B testing
  abVariantId String? // "A", "B", etc. — tracks which variant generated this message

  createdAt DateTime @default(now())

  dialogue MktDialogue @relation(fields: [dialogueId], references: [id], onDelete: Cascade)

  @@index([dialogueId, createdAt])
  @@index([resendId])
  @@index([trackingId])
}

// ─── Deals ──────────────────────────────

enum MktDealDecision {
  PENDING
  APPROVED
  REJECTED
}

model MktDeal {
  id            String          @id @default(cuid())
  leadId        String
  projectId     String
  proposedPrice Int?
  agentSummary  String?
  adminDecision MktDealDecision @default(PENDING)
  adminNotes    String?

  createdAt DateTime  @default(now())
  decidedAt DateTime?

  lead    MktLead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  project MktProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([projectId])
  @@index([adminDecision])
}

// ─── Consultations ──────────────────────

model MktConsultation {
  id            String  @id @default(cuid())
  leadId        String?
  question      String
  context       String?
  adminResponse String?
  status        String  @default("pending") // pending | answered

  createdAt  DateTime  @default(now())
  answeredAt DateTime?

  lead MktLead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ─── Pending Replies (review mode) ──────

enum MktPendingStatus {
  PENDING
  APPROVED
  SENDING
  REJECTED
  SENT
  FAILED
}

model MktPendingReply {
  id         String  @id @default(cuid())
  leadId     String
  dialogueId String?
  channel    String // "email" | "telegram"
  recipient  String
  subject    String?
  body       String
  context    String? // JSON (type: initial|reply|deal_accept|consultation_answer)

  status        MktPendingStatus @default(PENDING)
  editedBody    String?
  editedSubject String?
  adminNotes    String?

  // A/B testing
  abVariantId String? // "A", "B", etc.

  createdAt DateTime  @default(now())
  decidedAt DateTime?
  sentAt    DateTime?
  sendAfter DateTime? // отложенная отправка (yt-parser send_after)

  lead     MktLead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dialogue MktDialogue? @relation(fields: [dialogueId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([leadId])
}

// ─── Search Tasks & Runs ────────────────

model MktSearchTask {
  id            String        @id @default(cuid())
  workspaceId   String
  name          String
  source        MktLeadSource
  keywords      String? // comma-separated
  hashtags      String?
  country       String?
  language      String?
  category      String?
  minSubs       Int?
  maxSubs       Int?
  minEngagement Float?
  sortBy        String? // relevance | date | viewCount
  maxResults    Int           @default(100)

  // Schedule
  cronExpression String? // null = manual only
  isEnabled      Boolean @default(true)

  // Last run info
  lastRunAt     DateTime?
  lastRunStatus String? // ok | error
  lastRunFound  Int?
  lastRunNew    Int?
  lastRunCost   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs      MktSearchRun[]

  @@index([workspaceId])
}

model MktSearchRun {
  id     String        @id @default(cuid())
  taskId String
  source MktLeadSource

  found      Int     @default(0)
  newLeads   Int     @default(0)
  cost       Float   @default(0)
  durationMs Int?
  status     String  @default("running") // running | ok | error
  error      String?
  params     String? // JSON snapshot of search params

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  task MktSearchTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, startedAt])
}

// ─── Segments ───────────────────────────

model MktSegment {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  filters     String // JSON — {source, minSubs, maxSubs, country, tags, hasEmail, scoreLevel, ...}
  leadCount   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─── Templates ──────────────────────────

model MktTemplate {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  channel     String // "email" | "telegram"
  language    String  @default("ru")
  subject     String?
  body        String // with {{variables}}
  category    String? // initial | followup_1 | followup_2 | custom

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─── Knowledge (RAG for outreach AI) ────

enum MktKnowledgeStatus {
  PENDING
  INDEXING
  INDEXED
  FAILED
}

model MktKnowledgeDoc {
  id          String             @id @default(cuid())
  workspaceId String
  projectId   String?
  kind        String // "text" | "url" | "file"
  title       String
  source      String? // URL or filename
  mime        String?
  sizeBytes   Int?
  content     String
  checksum    String?
  chunksCount Int                @default(0)
  status      MktKnowledgeStatus @default(PENDING)
  error       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks    MktKnowledgeChunk[]

  @@index([workspaceId, status])
}

model MktKnowledgeChunk {
  id         String  @id @default(cuid())
  docId      String
  position   Int
  chunkText  String
  embedding  String? // JSON float array (SQLite has no vector type)
  tokenCount Int?

  createdAt DateTime @default(now())

  doc MktKnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId, position])
}

// ─── Daily Counters ─────────────────────

model MktDailyCounter {
  id                String @id @default(cuid())
  workspaceId       String
  dateKey           String // "2026-05-18"
  emailsSent        Int    @default(0)
  tgSent            Int    @default(0)
  tokensIn          Int    @default(0)
  tokensOut         Int    @default(0)
  tokensCacheRead   Int    @default(0)
  tokensCacheCreate Int    @default(0)
  costUsd           Float  @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, dateKey])
  @@index([workspaceId, dateKey])
}

// ─── Settings (key-value) ───────────────

model MktSetting {
  id          String @id @default(cuid())
  workspaceId String
  key         String
  value       String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

// ─────────────────────────────────────────
// КОНТЕНТ-ПЛАН
// ─────────────────────────────────────────

enum CardStatus {
  IDEA // Идея
  DRAFT // Черновик
  REVIEW // На вычитке
  READY // Готово
  PUBLISHED // Опубликовано
  PAUSED // На паузе
}

enum VisualStatus {
  NONE // Нет визуала
  IN_REVIEW // Визуал на проверке
  OK // Визуал ок
}

enum CardPriority {
  LOW // Низкий
  MEDIUM // Средний
  HIGH // Высокий
}

enum CardChannel {
  ALL // Все каналы
  TELEGRAM
  INSTAGRAM
  X
  TIKTOK
  YOUTUBE
  FACEBOOK
}

enum CardFormat {
  POST // Пост
  CAROUSEL // Карусель
  REELS // Рилс
  STORIES // Сторис
  VIDEO // Видео
}

enum MediaType {
  IMAGE
  VIDEO
}

model ContentCard {
  id          String @id @default(cuid())
  workspaceId String

  authorId   String
  assigneeId String? // ответственный (owner)

  title   String
  channel CardChannel
  format  CardFormat

  priority     CardPriority @default(MEDIUM)
  status       CardStatus   @default(DRAFT)
  visualStatus VisualStatus @default(NONE)

  publishDate DateTime?

  visualBrief  String? // ТЗ визуала
  visualLink   String? // ссылка на визуал / макет / файл
  text         String? // финальный текст / сценарий / тезисы
  workComment  String? // рабочий комментарий автора
  adminComment String? // админ-комментарий (модератор)

  publishedUrl        String? // ссылка на опубликованный пост
  publishedExternalId String? // id поста во внешней системе (для автопубликации)

  // Гейты публикации (текст считается на лету по наличию text)
  autoPublish    Boolean @default(false)
  proofChecked   Boolean @default(false)
  visualApproved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author        User                 @relation("ContentCardAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  assignee      User?                @relation("ContentCardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  media         ContentMedia[]
  history       ContentCardHistory[]
  notifications Notification[]

  @@index([workspaceId])
  @@index([status])
  @@index([publishDate])
}

model ContentMedia {
  id        String    @id @default(cuid())
  cardId    String
  type      MediaType
  url       String // image: storagePath; video: внешняя ссылка
  name      String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  card ContentCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model ContentCardHistory {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  action    String // человекочитаемая запись, напр. «изменил «Тема»: «…» → «…»»
  field     String? // ключ поля при пополевом diff
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  card ContentCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
}
