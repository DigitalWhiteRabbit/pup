# Environment
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=pup-tg-service
APP_VERSION=0.1.0
APP_HOST=127.0.0.1
APP_PORT=8001
APP_WORKERS=2

# Redis (shared with PUP, separate db index)
REDIS_URL=redis://localhost:6379/5
CELERY_BROKER_URL=redis://localhost:6379/5
CELERY_RESULT_BACKEND=redis://localhost:6379/5

# Security
# Admin token for API mutations (shared with PUP or standalone)
ADMIN_TOKEN=replace-with-secure-token

# Master key for session encryption (AES-256-GCM)
# Generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
PUP_SECRET=

# Telegram (common credentials from https://my.telegram.org)
TELEGRAM_APP_ID=
TELEGRAM_APP_HASH=

# Anthropic (AI agents)
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=INFO

# Paths
DATA_DIR=./data
SESSIONS_DIR=./data/sessions
