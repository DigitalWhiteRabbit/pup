# ─── YouTube Data API ───────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key

# ─── AI (Anthropic Claude) ──────────────────────────────────
# Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email outreach (Resend) ────────────────────────────────
# Регистрация: https://resend.com → бесплатно до 3000 писем/мес
# 1. Добавь домен в Resend, добавь DNS записи (SPF, DKIM, DMARC)
# 2. Создай API key в Resend Dashboard
RESEND_API_KEY=re_...
EMAIL_FROM=outreach@yourdomain.com
EMAIL_DOMAIN=yourdomain.com

# IMAP для приёма ответов (можно использовать Gmail или почту своего домена)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your@gmail.com
# Для Gmail: создай App Password: https://myaccount.google.com/apppasswords
IMAP_PASS=your_app_password

# ─── Telegram Outreach (gramjs MTProto) ─────────────────────
# Получить: https://my.telegram.org/apps
# ⚠️ Используй ОТДЕЛЬНЫЙ Telegram-аккаунт (не основной!)
TG_API_ID=12345678
TG_API_HASH=abc123def456...
TG_PHONE=+79991234567
# Дебаунс генерации ответа на входящие TG: если блогер шлёт пачку сообщений
# подряд, агент отвечает ОДИН раз после «тишины» (мс). Дефолт 12000 (12с).
TG_REPLY_DEBOUNCE_MS=12000

# ─── Admin Telegram Bot ─────────────────────────────────────
# Создай бота через @BotFather в Telegram, получи токен
ADMIN_BOT_TOKEN=1234567890:ABC...
# Узнай свой chat_id: напиши боту /start и посмотри в логах
ADMIN_TG_CHAT_ID=123456789

# ─── Admin API token (защита мутаций) ───────────────────────
# Если задан — все мутации /api/agent, /api/deals, /api/dialogues,
# /api/telegram, /api/leads, /api/consultations требуют заголовок
# x-admin-token: <этот токен>. Если пусто — защита ВЫКЛЮЧЕНА (только dev).
ADMIN_TOKEN=

# ─── AI models ──────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_SUMMARY=claude-haiku-4-5
CLAUDE_MODEL_COMPLEX=claude-opus-4-6

# ─── Outreach limits ────────────────────────────────────────
DAILY_CAP_EMAIL=200
DAILY_CAP_TG=50
MAX_REPLIES_PER_TICK=3
LOOP_MESSAGE_LIMIT=20

# ─── GDPR unsubscribe ───────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
UNSUBSCRIBE_SECRET=
# Публичный URL сервера (без слеша в конце)
BASE_URL=https://yourdomain.com

# ─── Dry-run режим (безопасный первый запуск) ───────────────
# true = генерит питчи, пишет в БД, НО не отправляет письма
# Результаты в таблице dry_run_log
DRY_RUN=false

# Единый Prisma-Postgres PUP (контейнер pup-postgres-dev из корневого docker-compose.yml)
DATABASE_URL="postgresql://pup:pup@localhost:5432/pup?schema=public"

# Шифрование секретов TG-аккаунтов (AES-256-GCM). Должен совпадать с PUP (lib/services/crypto.service.ts).
# Берётся ENCRYPTION_KEY, иначе AUTH_SECRET. Значение — как в корневом .env PUP.
AUTH_SECRET="<same-as-PUP-AUTH_SECRET>"
# ENCRYPTION_KEY="<optional-override>"
