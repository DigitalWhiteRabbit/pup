# =============================================================================
# ПУП — Пульт Управления Проектами
# Скопируйте в .env и заполните значения
# =============================================================================

# --- Database (Postgres во всех средах; dev — docker compose up -d) ---
DATABASE_URL="postgresql://pup:pup@localhost:5432/pup?schema=public"
# Production: DATABASE_URL="postgresql://user:pass@localhost:5432/pup?connection_limit=10&pool_timeout=30"
# Legacy SQLite (до стандартизации): DATABASE_URL="file:./dev.db"

# --- Authentication (ОБЯЗАТЕЛЬНО сгенерировать!) ---
# Генерация: openssl rand -base64 32
AUTH_SECRET="GENERATE-WITH-openssl-rand-base64-32"
NEXTAUTH_SECRET="SAME-AS-AUTH_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# --- Chat JWT (ОБЯЗАТЕЛЬНО для публичного чат-виджета) ---
# Генерация: openssl rand -base64 32
CHAT_JWT_SECRET="GENERATE-WITH-openssl-rand-base64-32"

# --- Telegram Bot (опционально) ---
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your_bot_username"

# --- Telegram Admin Notifications (опционально) ---
# Send-only bot for deploy/error notifications
ADMIN_BOT_TOKEN=""
ADMIN_TG_CHAT_ID=""

# --- AI / Anthropic Claude (для AI-агента в тикетах и marketing) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Groq (бесплатная транскрипция Whisper, для голосовых сообщений) ---
GROQ_API_KEY=""

# --- Marketing / Email Outreach (опционально) ---
# Resend (отправка email)
RESEND_API_KEY=""
EMAIL_FROM="partnerships@your-domain.com"
RESEND_SENDER_NAME=""

# IMAP (получение ответов)
IMAP_HOST=""
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASS=""

# Telegram Outreach (отправка сообщений через TG, опционально)
TG_API_ID=""
TG_API_HASH=""
TG_PHONE=""

# Apify (парсинг, опционально)
APIFY_TOKEN=""

# --- TURN Server (для голосовых каналов через NAT/firewall) ---
# Option 1: Metered.ca (бесплатно 500MB/мес)
TURN_PROVIDER="metered"
METERED_DOMAIN="your-domain.metered.live"
METERED_API_KEY=""

# Option 2: Custom coturn
# TURN_PROVIDER="custom"
# TURN_URL="turn:your-server.com:3478"
# TURN_USERNAME="user"
# TURN_PASSWORD="pass"

# Option 3: Twilio NTS
# TURN_PROVIDER="twilio"
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""

# --- YouTube Parser (опционально, для marketing модуля) ---
YOUTUBE_API_KEY=""
# Пул ключей (JSON-массив строк, для ротации). Приоритет выше YOUTUBE_API_KEY.
# YT_API_KEY_POOL='["key1","key2","key3"]'
# Internal URL for yt-parser proxy (PUP fetches data from parser on this address)
# YT_PARSER_URL="http://localhost:3001"

# --- File Storage ---
STORAGE_DRIVER="local"
UPLOAD_DIR="./uploads"

# --- Deploy (опционально) ---
DEPLOY_CHAT_ID=""
GITHUB_WEBHOOK_SECRET=""

# --- Initial Admin (для prisma/seed.ts) ---
INITIAL_ADMIN_LOGIN="admin"
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="change-me-on-first-login"

# --- Demo data (опционально) ---
SEED_DEMO_DATA="false"

# =============================================================================
# YouTube Parser (tools/yt-parser/) — дополнительные переменные
# Эти переменные нужны только если вы запускаете парсер отдельно
# =============================================================================

# --- Авторизация парсера (опционально, если не задано — без защиты) ---
# AUTH_LOGIN=""
# AUTH_CODE=""
# ADMIN_TOKEN=""

# --- Сессии парсера ---
# SESSION_SECRET=""
# SESSION_TTL_DAYS="14"

# --- Отписка от email ---
# UNSUBSCRIBE_SECRET=""

# --- AI-модели (по умолчанию используются актуальные Claude) ---
# CLAUDE_MODEL="claude-sonnet-4-6"
# CLAUDE_MODEL_SUMMARY="claude-haiku-4-5"
# CLAUDE_MODEL_COMPLEX="claude-opus-4-6"

# --- Knowledge Base (RAG, настройки чанков) ---
# KNOWLEDGE_MODEL="Xenova/multilingual-e5-small"
# KNOWLEDGE_CHUNK_SIZE="800"
# KNOWLEDGE_CHUNK_OVERLAP="100"
# KNOWLEDGE_TOP_K="6"

# --- Outreach Worker (лимиты и режимы) ---
# DRY_RUN="false"
# REVIEW_MODE="false"
# MAX_REPLIES_PER_TICK="3"
# LOOP_MESSAGE_LIMIT="20"
# DAILY_CAP_EMAIL="200"
# DAILY_CAP_TG="50"
# FOLLOWUP_ENABLED="false"
# FOLLOWUP_DELAY_DAYS="3"
# FOLLOWUP_MAX_ATTEMPTS="2"

# --- Таймзона счётчиков (смещение в минутах от UTC) ---
# COUNTERS_TZ_OFFSET_MIN="180"

# --- Контент-план: автопубликация (задел, phase 2; выключена по умолчанию) ---
# CRON_SECRET="" # задать, чтобы включить POST /api/cron/content-autopublish
# Telegram-канал автопубликации настраивается per-workspace в MktSetting
# (key="content.tg.channelId", value="@channel" или chat_id) — не в .env
