# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your_bot_username"

# Chat JWT (public chat customer identity)
CHAT_JWT_SECRET="your-chat-jwt-secret-change-in-production"

# OpenAI (for AI agent copilot/autopilot)
OPENAI_API_KEY="sk-..."

# File Storage
STORAGE_DRIVER="local"
UPLOAD_DIR="./uploads"

# Initial Admin (used by prisma/seed.ts)
INITIAL_ADMIN_LOGIN="admin"
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="change-me-on-first-login"

# Demo data (optional, set to "true" for local dev convenience)
SEED_DEMO_DATA="false"
