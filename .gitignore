# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# uploads (file storage)
/uploads/

# database
prisma/dev.db
dev.db.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# yt-parser runtime data (not code)
tools/yt-parser/presets.json
tools/yt-parser/history.json
tools/yt-parser/cache.json
tools/yt-parser/errors.log
tools/yt-parser/data/

# Local claude-code scheduling artifact (not code)
.claude/scheduled_tasks.lock

# QA screenshots (dev artifacts, not for prod)
public/qa-screenshots/

# Local DB backups (migration safety net, never commit)
_backups/

# tg-service runtime artifact (celery beat scheduler state)
tools/tg-service/celerybeat-schedule.db
